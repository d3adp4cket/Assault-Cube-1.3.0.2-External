<Window x:Class="AssaultCubeExternal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assault Cube 1.3.0.2 External" Height="560" Width="380"
        WindowStyle="None" ResizeMode="NoResize"
        Background="Transparent" AllowsTransparency="True"
        Topmost="True" ShowInTaskbar="False">

  <Window.Resources>

    <!-- Toggle -->
    <Style x:Key="Toggle" TargetType="ToggleButton">
      <Setter Property="Width"  Value="44"/>
      <Setter Property="Height" Value="22"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Grid>
              <Border x:Name="Tr" CornerRadius="11" Background="#2C2C2C" BorderBrush="#3A3A3A" BorderThickness="1"/>
              <Border x:Name="Th" Width="16" Height="16" CornerRadius="8"
                      Background="#555" HorizontalAlignment="Left"
                      Margin="3,0,0,0" VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Tr" Property="Background"  Value="#003300"/>
                <Setter TargetName="Tr" Property="BorderBrush" Value="#003300"/>
                <Setter TargetName="Th" Property="Background"  Value="#39FF14"/>
                <Setter TargetName="Th" Property="HorizontalAlignment" Value="Right"/>
                <Setter TargetName="Th" Property="Margin" Value="0,0,3,0"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Chrome button -->
    <Style x:Key="Btn" TargetType="Button">
      <Setter Property="Width"  Value="26"/>
      <Setter Property="Height" Value="26"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#666"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="3">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#DDD"/>
                <Setter Property="Background" Value="#2A2A2A"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Tab button -->
    <Style x:Key="Tab" TargetType="RadioButton">
      <Setter Property="Cursor"     Value="Hand"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
      <Setter Property="FontSize"   Value="12"/>
      <Setter Property="Foreground" Value="#555"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Padding"    Value="0,10"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Bd" Background="Transparent"
                    BorderBrush="Transparent" BorderThickness="0,0,0,2"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter Property="Foreground" Value="#39FF14"/>
                <Setter TargetName="Bd" Property="BorderBrush" Value="#39FF14"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#AAA"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <!-- Root -->
  <Border Background="#020202" CornerRadius="8" BorderBrush="#171717" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>
        <RowDefinition Height="30"/>
        <RowDefinition Height="38"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="28"/>
      </Grid.RowDefinitions>

      <!-- TITLEBAR -->
      <Border Grid.Row="0" CornerRadius="8,8,0,0" Background="#070707"
              BorderBrush="#171717" BorderThickness="0,0,0,1"
              MouseLeftButtonDown="TitleBar_MouseDown">
        <Grid Margin="14,0,8,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Assault Cube" FontFamily="Consolas" FontWeight="SemiBold" FontSize="13" Foreground="#39FF14"/>
            <TextBlock Text="1.3.0.2 External" FontFamily="Consolas" FontSize="13" Foreground="#39FF14" Margin="5,0,0,0"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Style="{StaticResource Btn}" Content="─" Click="MinimizeClick"/>
            <Button Style="{StaticResource Btn}" Content="✕" Click="CloseClick" Margin="2,0,0,0"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- STATUS -->
      <Border Grid.Row="1" Background="#070707" Padding="14,0"
              BorderBrush="#171717" BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#555" Margin="0,0,8,0"/>
          <TextBlock x:Name="StatusText" Text="Waiting for process"
                     FontFamily="Consolas" FontSize="11" Foreground="#555"/>
          <TextBlock x:Name="PlayerNameText" FontFamily="Consolas" FontSize="11"
                     Foreground="#39FF14" Margin="12,0,0,0"/>
        </StackPanel>
      </Border>

      <!-- TABS -->
      <Border Grid.Row="2" Background="#070707" BorderBrush="#171717" BorderThickness="0,0,0,1">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition/></Grid.ColumnDefinitions>
          <RadioButton x:Name="TabPlayer" Grid.Column="0" Style="{StaticResource Tab}"
                       Content="Player" GroupName="tabs" IsChecked="True"/>
        </Grid>
      </Border>

      <!-- CONTENT -->
      <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Hidden">
        <Grid>

          <!-- PLAYER TAB -->
          <StackPanel x:Name="PlayerPanel" Margin="14,14,14,0">

            <!-- HP / Armor -->
            <Border Background="#040404" CornerRadius="6" Padding="14,12"
                    BorderBrush="#171717" BorderThickness="1" Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="1"/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                  <TextBlock Text="HEALTH" FontFamily="Consolas" FontSize="9" Foreground="#555" HorizontalAlignment="Center"/>
                  <TextBlock x:Name="HealthVal" Text="—" FontFamily="Consolas" FontWeight="Bold" FontSize="26" Foreground="#39FF14" HorizontalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#171717" Width="1"/>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                  <TextBlock Text="ARMOR" FontFamily="Consolas" FontSize="9" Foreground="#555" HorizontalAlignment="Center"/>
                  <TextBlock x:Name="ArmorVal" Text="—" FontFamily="Consolas" FontWeight="Bold" FontSize="26" Foreground="#39FF14" HorizontalAlignment="Center"/>
                </StackPanel>
              </Grid>
            </Border>

            <!-- Feature rows -->
            <Border Background="#040404" CornerRadius="6" Padding="14,0"
                    BorderBrush="#171717" BorderThickness="1" Margin="0,0,0,8">
              <StackPanel>
                <!-- God Mode -->
                <Grid Margin="0,11,0,11">
                  <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="God Mode" FontFamily="Consolas" FontSize="12" Foreground="#39FF14"/>
                    <TextBlock Text="Lock HP and armor at 999" FontFamily="Consolas" FontSize="10" Foreground="#555" Margin="0,2,0,0"/>
                  </StackPanel>
                  <ToggleButton x:Name="Toggle_GodMode" Grid.Column="1" Style="{StaticResource Toggle}"
                                VerticalAlignment="Center" Checked="Feature_Changed" Unchecked="Feature_Changed"/>
                </Grid>
                <Border Background="#171717" Height="1"/>
                <!-- Infinite Ammo -->
                <Grid Margin="0,11,0,11">
                  <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="Infinite Ammo" FontFamily="Consolas" FontSize="12" Foreground="#39FF14"/>
                    <TextBlock Text="All weapons refilled each tick" FontFamily="Consolas" FontSize="10" Foreground="#555" Margin="0,2,0,0"/>
                  </StackPanel>
                  <ToggleButton x:Name="Toggle_Ammo" Grid.Column="1" Style="{StaticResource Toggle}"
                                VerticalAlignment="Center" Checked="Feature_Changed" Unchecked="Feature_Changed"/>
                </Grid>
                <Border Background="#171717" Height="1"/>
                <!-- Fast Fire -->
                <Grid Margin="0,11,0,11">
                  <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="Fast Fire" FontFamily="Consolas" FontSize="12" Foreground="#39FF14"/>
                    <TextBlock Text="Zero fire delay on all weapons" FontFamily="Consolas" FontSize="10" Foreground="#555" Margin="0,2,0,0"/>
                  </StackPanel>
                  <ToggleButton x:Name="Toggle_FastFire" Grid.Column="1" Style="{StaticResource Toggle}"
                                VerticalAlignment="Center" Checked="Feature_Changed" Unchecked="Feature_Changed"/>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Ammo grid -->
            <TextBlock Text="AMMO" FontFamily="Consolas" FontSize="9" Foreground="#444" Margin="2,0,0,6"/>
            <Border Background="#040404" CornerRadius="6" Padding="14,12"
                    BorderBrush="#171717" BorderThickness="1" Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <TextBlock Text="AR"      FontFamily="Consolas" FontSize="9" Foreground="#555"/>
                  <TextBlock x:Name="AmmoAR"      Text="—" FontFamily="Consolas" FontWeight="SemiBold" FontSize="14" Foreground="#39FF14"/>
                  <TextBlock Text="SMG"     FontFamily="Consolas" FontSize="9" Foreground="#555" Margin="0,8,0,0"/>
                  <TextBlock x:Name="AmmoSMG"     Text="—" FontFamily="Consolas" FontWeight="SemiBold" FontSize="14" Foreground="#39FF14"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                  <TextBlock Text="SNIPER"  FontFamily="Consolas" FontSize="9" Foreground="#555"/>
                  <TextBlock x:Name="AmmoSniper"  Text="—" FontFamily="Consolas" FontWeight="SemiBold" FontSize="14" Foreground="#39FF14"/>
                  <TextBlock Text="PISTOL"  FontFamily="Consolas" FontSize="9" Foreground="#555" Margin="0,8,0,0"/>
                  <TextBlock x:Name="AmmoPistol"  Text="—" FontFamily="Consolas" FontWeight="SemiBold" FontSize="14" Foreground="#39FF14"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Text="SHOTGUN" FontFamily="Consolas" FontSize="9" Foreground="#555"/>
                  <TextBlock x:Name="AmmoShotgun" Text="—" FontFamily="Consolas" FontWeight="SemiBold" FontSize="14" Foreground="#39FF14"/>
                  <TextBlock Text="GRENADE" FontFamily="Consolas" FontSize="9" Foreground="#555" Margin="0,8,0,0"/>
                  <TextBlock x:Name="AmmoGrenade" Text="—" FontFamily="Consolas" FontWeight="SemiBold" FontSize="14" Foreground="#39FF14"/>
                </StackPanel>
              </Grid>
            </Border>

            <!-- Position -->
            <TextBlock Text="POSITION" FontFamily="Consolas" FontSize="9" Foreground="#444" Margin="2,0,0,6"/>
            <Border Background="#040404" CornerRadius="6" Padding="14,10"
                    BorderBrush="#171717" BorderThickness="1">
              <TextBlock x:Name="PosText" Text="X: —   Y: —   Z: —"
                         FontFamily="Consolas" FontSize="11" Foreground="#555"/>
            </Border>
          </StackPanel>

        </Grid>
      </ScrollViewer>

      <!-- FOOTER -->
      <Border Grid.Row="4" Background="#070707" CornerRadius="0,0,8,8"
              BorderBrush="#171717" BorderThickness="0,1,0,0" Padding="14,0">
        <TextBlock x:Name="FooterLog" Text="ready"
                   FontFamily="Consolas" FontSize="10" Foreground="#3A3A3A" VerticalAlignment="Center"/>
      </Border>

    </Grid>
  </Border>
</Window>

# Auto detect text files and perform LF normalization
* text=auto

# C# source files
*.cs text diff=csharp
*.xaml text
*.csproj text merge=union
*.sln text merge=union

# Binaries
*.dll binary
*.exe binary
*.pdb binary
*.so binary
*.dylib binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
